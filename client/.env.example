# Client environment variables for Vercel deployment

# API server URL (required) - Set this to your Render.com backend URL in production
VITE_API_URL=https://titan-api.onrender.com

# Firebase configuration (required for authentication)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# OpenAI API key (for client-side AI features if needed)
VITE_OPENAI_API_KEY=

# Feature flags
VITE_ENABLE_FINDOM=true
VITE_ENABLE_BROWSER_AUTOMATION=true
VITE_ENABLE_ANALYTICS=false

# Note: Create a .env.local file with your actual values for local development
# Vercel will use the environment variables you set in the Vercel dashboard