# Root environment variables
# These will be used by build scripts

# Build configuration
BUILD_ENV=development

# Version information
VERSION=1.0.0

# Git configuration
GIT_REPO=https://github.com/MiahMontgomery/Titan.git
GIT_BRANCH=main

# Deployment URLs
RENDER_URL=https://titan-api.onrender.com
VERCEL_URL=https://titan-client.vercel.app

# These need to be duplicated in server/.env and client/.env
OPENAI_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_APP_ID=