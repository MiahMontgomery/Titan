# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORGANIZATION=your_organization_id_here_optional

# Agent Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARN, ERROR, CRITICAL
AGENT_AUTO_CONFIRM=false  # Set to true to auto-confirm all prompts
MAX_RETRY_ATTEMPTS=3  # Maximum number of retry attempts for failed tasks

# Project Configuration
DEFAULT_PROJECT_NAME=autonomously_generated_project
DEFAULT_LANGUAGE=typescript  # Default programming language